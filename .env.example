# ===== Credenciais WayMB (obrigatórias) =====
# Obtidas no painel WayMB > API
WAYMB_CLIENT_ID=
WAYMB_CLIENT_SECRET=

# E-mail da conta WayMB onde o dinheiro é depositado
WAYMB_ACCOUNT_EMAIL=

# Base URL da API (deixar em branco usa o default)
WAYMB_BASE_URL=https://api.waymb.com

# ===== URLs (opcionais) =====
# URL absoluta onde a WayMB notifica updates de status do pagamento
# Aponta para a função /api/webhook do teu deploy:
#   ex: https://meudominio.vercel.app/api/webhook
CALLBACK_URL=

# URLs de redirecionamento usadas pela WayMB no fluxo hospedado (opcionais —
# o nosso fluxo usa polling, mas estes campos ficam registados na transação)
SUCCESS_URL=
FAILED_URL=
